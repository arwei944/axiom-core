#!/bin/sh
# axiom-core pre-commit hook
# Runs cargo fmt, build, clippy, test, and architecture verify
# Install: cp .githooks/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit
# Or globally: git config core.hooksPath .githooks

set -e

echo "=== axiom pre-commit ==="

STASHED=0
if ! git diff --cached --quiet; then
    if ! git diff --quiet; then
        echo "Stashing unstaged changes..."
        git stash -q --keep-index
        STASHED=1
    fi
fi

cleanup() {
    if [ "$STASHED" -eq 1 ]; then
        echo "Restoring unstaged changes..."
        git stash pop -q
    fi
}
trap cleanup EXIT

echo "[1/5] cargo fmt --check..."
cargo fmt --all -- --check

echo "[2/5] cargo build..."
cargo build --workspace

echo "[3/5] cargo clippy..."
cargo clippy --workspace -- -D warnings

echo "[4/5] cargo test..."
cargo test --workspace

echo "[5/5] axiom verify..."
if ! command -v axm >/dev/null 2>&1; then
    cargo run --quiet --bin axm -- verify
else
    axm verify
fi

echo ""
echo "All pre-commit checks passed."
